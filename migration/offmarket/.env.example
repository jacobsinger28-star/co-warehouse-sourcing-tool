# .env.example — copy to .env, fill in, never commit .env

DATABASE_URL=postgresql://user:pass@host:5432/nashville   # Supabase connection string
GOOGLE_MAPS_API_KEY=                                       # Street View Static + geocoding
ANTHROPIC_API_KEY=                                          # VLM site assessment
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
IMAGE_CACHE_DIR=./image_cache                               # gitignored
IMPORTS_DIR=./imports                                       # founder drops CSVs here:
                                                            #   trustee_delinquent.csv
                                                            #   listings.csv
                                                            #   submarkets.geojson

# --- AI calling (outreach/place_calls.py) — vendor still being chosen --------------------
CALL_PROVIDER=stub                                          # stub | bland | vapi | retell | ...
                                                            #   'stub' = no real calls (default, safe)
OUTREACH_COMPANY_NAME=                                       # spoken in the AI-disclosure opener
OUTREACH_CALLBACK_NUMBER=                                    # number the agent gives for callbacks

# --- Pipedrive CRM (sync/pipedrive_sync.py) — stub-safe until these are set --------------
PIPEDRIVE_API_TOKEN=                                         # personal/API token (Settings > API)
PIPEDRIVE_DOMAIN=                                            # the <subdomain> in <subdomain>.pipedrive.com
PIPEDRIVE_USER_ID=                                           # who warm-lead follow-up tasks assign to
PIPEDRIVE_FOLLOWUP_DAYS=1                                    # warm-lead task due-date offset (days)
