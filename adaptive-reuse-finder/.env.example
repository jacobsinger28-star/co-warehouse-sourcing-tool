# Copy to .env (gitignored) and fill in. The MVP (Chrome-extension human-VLM path) needs
# NEITHER of these — they are only for the V2 automated pipeline. Keys are held by Andrew
# (see ../offmarket-scraping/docs/TOOLS_REGISTRY.md for status + acquisition).

# Google Maps Platform — Street View Static API + metadata endpoint (V2 image source).
# Street View Static ≈ $7 / 1,000 images (10k/mo free); the metadata endpoint is free/unlimited.
GOOGLE_MAPS_API_KEY=

# Anthropic — Claude vision, for automated (non-human-in-the-loop) classification (V2).
ANTHROPIC_API_KEY=

# Optional: Overpass endpoint override for tools/sample_points.py (defaults to the public server).
# OVERPASS_URL=https://overpass-api.de/api/interpreter
